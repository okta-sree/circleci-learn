{
  "name": "circleci-learn",
  "version": "1.0.0",
  "description": "A math utility library to learn CircleCI step by step",
  "main": "src/index.js",
  "scripts": {
    "test": "jest --ci --reporters=default --reporters=jest-junit",
    "test:watch": "jest --watch",
    "lint": "eslint src/ --ext .js",
    "build": "echo '✅ Build complete (no bundler needed for this project)'"
  },
  "jest": {
    "testEnvironment": "node",
    "testMatch": ["**/tests/**/*.test.js"],
    "coverageDirectory": "coverage",
    "collectCoverageFrom": ["src/**/*.js"]
  },
  "dependencies": {},
  "devDependencies": {
    "eslint": "^8.57.0",
    "jest": "^29.7.0",
    "jest-junit": "^16.0.0"
  }
}
